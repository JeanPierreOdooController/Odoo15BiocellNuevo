<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record id="view_procedure_clinic_form" model="ir.ui.view">
		<field name="name">procedure.clinic.form</field>
		<field name="model">procedure.clinic</field>
		<field name="arch" type="xml">
			<form string="Registro de Procedimiento Clínico">
				<sheet>
					<group>
						<group>
							<field name="procedure_id" required="1"/>
						</group>
						<group>
							<field name="name" required="1"/>
						</group>
					</group>
				</sheet>
			</form>
		</field>
	</record>

	<record id="view_procedure_clinic_list" model="ir.ui.view">
		<field name="name">procedure.clinic.list</field>
		<field name="model">procedure.clinic</field>
		<field name="arch" type="xml">
			<tree>
				<field name="procedure_id" optional="show"/>
				<field name="name" optional="show"/>
			</tree>
		</field>
	</record>

	<record id="action_procedure_clinic_form" model="ir.actions.act_window">
		<field name="name">Procedimientos Clínicos</field>
		<field name="res_model">procedure.clinic</field>
		<field name="view_mode">tree,form</field>
		<field name="view_id" ref="view_procedure_clinic_list"/>
		<field name="help" type="html">
		  <p class="o_view_nocontent_smiling_face">
			Crea tu primera tabla de Procedimientos Clínicos aqui
		  </p>
		</field>
	</record>

	<menuitem id='menu_action_procedure_clinic_form' 
				  parent='sale.menu_sale_config' 
				  action="action_procedure_clinic_form"
				  sequence="300"/>
</odoo>
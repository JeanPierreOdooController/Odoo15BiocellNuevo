<?xml version="1.0" encoding="utf-8"?>
<odoo>
    

    <template id="report_saleorder_document">
            <div class="header">
                        <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
                        <div class="row pt-2" style="font-family: Arial;font-size:11px">
                            <div class="col-12 pt-0 row">
                                <div class="col-3">
                                    <center><img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)"
                                                     alt="Logo" style="width: 150px; top: 0 ; vertical-align: baseline;"
                                                     class="mt-0 pt-0"
                                                /></center>
                                               

                                </div>
                                <div class="col-9">
                                    <p style="font-size: 14px;">
                                     BIOCELLS GENOMICS SOCIEDAD ANONIMA CERRADA - BIOGENOMICS S.A.C. <br/>
                                        RUC: 20607531600 <br/>
                                        Av. Santa Maria 140 Int. 201, Lima, Perú - CMS Grau <br/>
                                        Telf: +51 1 6952357 <br/>
                                        Correo Electrónico: biocells.peru@biocells.pe 
                                    </p>
                                </div>
                            </div>
                        </div>
            </div>
            


            <div class="article o_report_layout_standard" style="font-family: Arial;font-size:12px">
                <div class="page">
                    <div class="oe_structure"/>
                        <h2>
                        <center>
                            <b><t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                                <span t-if="doc.state not in ['draft','sent']">PEDIDO - <span  t-field="doc.name"/> </span>
                                <span t-if="doc.state in ['draft','sent']" >PRESUPUESTO - <span  t-field="doc.name"/> </span>
                            </t></b>
                        </center></h2>
                    <div class="row pt-2" >
                        <div  class="col-7" >
                         <div  class="row" >
                                <div  class="col-12 " >
                                   
                                       
                                    <t t-set="day" t-value="doc.date_order.strftime('%d')" />
                                    <t t-set="month" t-value="doc.date_order.strftime('%B')" />
                                    
                                    <t t-set="year" t-value="doc.date_order.strftime('%Y')" />

                                    <p  class="m-0 p-1"><span class="font-weight-bold"></span>Lima ,<t t-esc="month.replace('January','Enero').replace('February','Febrero').replace('March','Marzo').replace('April','Abril').replace('May','Mayo').replace('June','Junio').replace('July','Julio').replace('August','Agosto').replace('September','Septiembre').replace('October','Octubre').replace('November','Noviembre').replace('December','Diciembre')"/> <span t-esc="day"/>, <span t-esc="year"/></p>
                                </div>
                            
                            </div>
                            <div  class="row" >
                                <div  class="col-3 " >
                                    <p  class="m-0 p-1"><span class="font-weight-bold">Facturar A</span> </p>
                                </div>
                                <div  class="col-9 " >
                                    <p  class="m-0 p-1">: <span  t-field="doc.partner_id.name"/></p>
                                </div>
                            </div>
                            <div  class="row" >
                                <div  class="col-3 " >
                                    <p  class="m-0 p-1"><span class="font-weight-bold">Calle</span> </p>
                                </div>
                                <div  class="col-9 " >
                                    <p  class="m-0 p-1">: <span  t-field="doc.partner_id.contact_address"/></p>
                                </div>
                            </div>
                             <div  class="row" >
                                <div  class="col-3 " >
                                    <p class="m-0 p-1"><span class="font-weight-bold" style="font-size:0.85em;">Asesor comercial</span> </p>
                                </div>
                                <div  class="col-9 " >
                                    <p  class="m-0 p-1">: <span  t-field="doc.user_id.name"/></p>
                                </div>
                            </div>
                            <p  class="m-0 p-1"><span class="font-weight-bold">Distinguido/a.-:</span> </p>
                            <p  class="m-0 p-1"><span class="font-weight-bold">De acuerdo a lo solicitado, enviamos nuestra cotización</span> </p>
                        </div>
                        <div class="col-5">
                            
                            <div class="row" >
                                <div  class="col-5 " >
                                    <p  class="m-0 p-1"><span class="font-weight-bold">Teléfono </span></p>
                                </div>
                                <div  class="col-7 " >
                                    <b><p  class="m-0 p-1">: <span  t-field="doc.partner_id.phone"/></p></b>
                                </div>
                            </div>
                           

                        </div>

                    </div>
                    
                    <t t-set="descuento" t-value="False"/>
                    <t t-foreach="doc.order_line" t-as="line_descuento">
                        <t t-set="descuento" t-value="True if line_descuento.discount >0 else descuento"/>
                    </t>
                    <br/>
                    <table style=" border: 1px solid #000; border-collapse: collapse; width: 100%;">
                        <thead style="display: table-row-group">
                            <tr style="background-color: #f2f2f2;">
                                <th style="border: 1px solid #000; padding: 5px; width: 5%;" name="th_cant" class="text-center">Artículo</th>
                                <th style="border: 1px solid #000; padding: 5px;" name="th_cod" class="text-center">Código</th>
                                <th style="border: 1px solid #000; padding: 5px;  width: 40%;" name="th_description" class="text-center">Descripción</th>
                                <th style="border: 1px solid #000; padding: 5px;" name="th_um" class="text-center">Und.</th>
                                <th style="border: 1px solid #000; padding: 5px;" name="th_subtotal" class="text-center">Cant. </th>
                                <th style="border: 1px solid #000; padding: 5px; width: 10%;" name="th_quantity" class="text-center">P. Unit.</th>
                               
                                 
                                <t t-if="descuento">
                                        <th class="text-center" name="td_descuento" style="border: 1px solid #000; padding: 3px !important; margin: 0px !important;">
                                            Descuento
                                        </th>
                                    </t>
                                  
                                <th style="border: 1px solid #000; padding: 5px;  width: 10%;" name="th_subtotal" class="text-center">Total </th>
                            </tr>
                        </thead>
                        <tbody class="sale_tbody">
                            <t t-set="counter" t-value="0"/>
                            <t t-foreach="doc.order_line" t-as="line">
                                <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                    
                                    
                                    

                                    <t t-if="not line.display_type">
                                        <t t-set="counter" t-value="counter + 1"/>
                                        <td class="text-center"  style="border: 1px solid #000;  width: 5% !important;"><t t-esc="counter"/></td>
                                        
                                        <td name="td_code" class="text-right"
                                            style="border: 1px solid #000; padding: 3px !important; margin: 0px !important;"  >
                                                <span t-field="line.product_id.default_code"/>
                                        </td>
                                        <td name="td_code_product" class="text-right"
                                            style="border: 1px solid #000; padding: 3px !important; margin: 0px !important;"  >
                                                <span t-field="line.product_id.name"/>
                                        </td>
                                         <td class="text-center" name="td_unid"
                                            style="border: 1px solid #000; padding: 3px !important; margin: 0px !important;"  >
                                                <span t-field="line.product_uom"/>
                                        </td>
                                         <td class="text-center" name="td_cantidad"
                                            style="border: 1px solid #000; padding: 3px !important; margin: 0px !important;"  >
                                                <span t-field="line.product_uom_qty"/>
                                        </td>
                                         <td class="text-right" name="td_precio_unit"
                                            style="border: 1px solid #000; padding: 3px !important; margin: 0px !important;"  >
                                            <span t-esc="doc.currency_id.symbol" />  <span t-field="line.price_unit"/>
                                        </td>
                                        <t t-if="descuento">
                                            <td class="text-right" name="td_descuento" style="border: 1px solid #000; padding: 3px !important; margin: 0px !important;">
                                                <span t-field="line.discount"/> %
                                            </td>
                                        </t>
                                         <td class="text-right" name="td_total"
                                            style="border: 1px solid #000; padding: 3px !important; margin: 0px !important;"  >
                                                <span t-field="line.price_subtotal"/>
                                        </td>
                                        
                                    </t>
                                </tr>

                            </t>
                        </tbody>
                    </table>
                    <br/>
                    <table style="width: 25%; float: right; ">
                        <tr>
                            <td style = " width: 10% !important; border: 1px solid black; padding: 3px !important; margin: 0px !important; background-color: #f2f2f2;"><b>Sub-Total</b></td>
                            <td style = "width: 15% !important;  border: 1px solid black; padding: 3px !important; margin: 0px !important;" class="text-right"> <span t-field="doc.amount_untaxed"/></td>
                        </tr>
                        <tr>
                            <td style = "width: 10% !important; border: 1px solid black;padding: 3px !important; margin: 0px !important; background-color: #f2f2f2;"><b>IGV (18%)</b></td>
                            <td style = "width: 15% !important; border: 1px solid black;padding: 3px !important; margin: 0px !important;" class="text-right"><span t-field="doc.amount_tax"/></td>
                        </tr>
                        <tr>
                            <td style = "width: 10% !important; border: 1px solid black;padding: 3px !important; margin: 0px !important;background-color: #f2f2f2;"><b>Total (<span t-esc="doc.currency_id.symbol" />)</b></td>
                            <td style = "width: 15% !important; border: 1px solid black;padding: 3px !important; margin: 0px !important;" class="text-right"><span t-field="doc.amount_total"/></td>
                        </tr>
                    </table>
                    
                    <br/>
                    <br/>
                    
                        <div  class="row" >
                            <div  class="col-3">
                                <p><span class="font-weight-bold"></span>Nombre del paciente </p>
                            </div>
                            <div  class="col-9"><span t-field="doc.name_patient"/></div>
                        </div>
                        <div  class="row" >
                            <div  class="col-3" >
                                <p><span class="font-weight-bold"></span>Nombre del doctor </p>
                            </div>
                            <div  class="col-9" >
                                <span t-field="doc.name_doctor"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-3">
                                <p><span class="font-weight-bold"/>Procedimiento Clínico </p>
                            </div>
                            <div class="col-9">
                                <span t-field="doc.procedure_clinic_id"/>
                            </div>
                        </div>
                        <br/>
                        <div  class="row" >
                            
                            <div  class="col-5" >
                                <p><b><u>Condiciones:</u></b></p>
                               
                            </div>
                            <div  class="col-7 " >
                                
                            </div>
                        </div>
                         <div  class="row" >
                            
                            <div  class="col-2" >
                                <p><span class="font-weight-bold"></span>Forma de pago </p>
                            </div>
                            <div  class="col-10 " >
                                 <span t-field="doc.payment_term_id.name"/>
                            </div>
                        </div>
                        <div  class="row" >
                            <div  class="col-2" >
                                <p><span class="font-weight-bold"></span>Tiempo de entrega</p>
                            </div>
                            <div  class="col-10 " >
                                 <t t-esc="doc.picking_policy.replace('direct','Lo antes posible').replace('one','Cuando todos los productos estén listos')"/>
                            </div>
                        </div>
                        <div  class="row" >
                            <div  class="col-2" >
                                <p><span class="font-weight-bold"></span>Validez de la oferta </p>
                            </div>
                            <t t-set="validity" t-value="doc.validity_date.strftime('%d/%m/%Y') if doc.validity_date else ' '" />
                            <div  class="col-10 " >
                                
                                 <span t-esc="validity"/>
                            </div>
                        </div>
                        
                 
                    <div>
                    <p>Sin otro particular y esperando su favorable respuesta, me despido.<br/>Atentamente,</p>
                        <center style="display:none;"><p  style="font-size: 14px;">Agregar firma de usuario</p><br/><br/>______________________________</center>
                        <p><u><b>Pagar a :</b></u></p>
                        <p>
                        <b>N° de cuenta corriente</b><br/>
                        BANCO DE CREDITO DEL PERU  S/ : 193-2647415-0-64<br/>
                        BANCO DE CREDITO DEL PERU S/ CCI: 00219300264741506411<br/><br/>
                        BANCO DE CREDITO DEL PERU $ : 193-9294084-1-44<br/>
                        BANCO DE CREDITO DEL PERU $ CCI: 00219300929408414415
                        </p>
  
                    </div>
                </div>
            </div>
            
    </template>

    <template id="sale.report_saleorder">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="biocell_formato_pedido_venta.report_saleorder_document" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>


    <record id="paperformat_id_cp" model="report.paperformat">
            <field name="name">Purchase Order Report</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">297</field>
            <field name="page_width">210</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">40</field>
            <field name="margin_bottom">15</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">30</field>
            <field name="dpi">90</field>
    </record>

    <report
            id="sale.action_report_saleorder"
            string="Proforma de Cotización Perú PDF"
            model="sale.order"
            report_type="qweb-pdf"
            file="sale.report_saleorder"
            name="sale.report_saleorder"
            print_report_name="(object.state in ('draft', 'sent') and 'Quotation - %s' % (object.name)) or 'Order - %s' % (object.name)"
            paperformat="biocell_formato_pedido_venta.paperformat_id_cp"
    />





        <record id="biocell_formato_pedido_venta_xls" model="ir.actions.report">
            <field name="name">Proforma de Cotización Perú Xlsx</field>
            <field name="model">sale.order</field>
            <field name="report_type">xlsx</field>
            <field name="report_name">biocell_formato_pedido_venta.biocell_formato_pedido_venta_xlsx</field>
            <field name="report_file">biocell_formato_pedido_venta.biocell_formato_pedido_venta_xlsx</field>
            <field name="binding_model_id" ref="model_sale_order"/>
            <field name="binding_type">report</field>
        </record>


</odoo>

<odoo>
	<data>
		<record id="view_move_form_inherit_landedcostunits" model="ir.ui.view">
			<field name="name">move.form.inherit.landedcostunits</field>
			<field name="model">account.move</field>
			<field name="inherit_id" ref="account.view_move_form"/>
			<field name="arch" type="xml">
				<data>
					<xpath expr="//notebook/page[@id='other_tab']/group/group/field[@name='payment_reference']" position="before">
						<field name="landed_cost_units_id" attrs="{'invisible': [('move_type', 'not in', ['in_invoice'])]}"/>
					</xpath>
				</data>
			</field>
		</record>
	</data>
</odoo>
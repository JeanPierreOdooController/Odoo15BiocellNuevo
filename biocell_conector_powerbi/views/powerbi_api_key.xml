<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="biocell_conector_powerbi_key_view_tree" model="ir.ui.view">
        <field name="name">powerbi.api.key.view.tree</field>
        <field name="model">powerbi.api.key</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name" readonly="1"/>
                <field name="token" />
            </tree>
        </field>
    </record>
    <record id="biocell_conector_powerbi_key_action" model="ir.actions.act_window">
        <field name="name">PowerBI Tokens API</field>
        <field name="res_model">powerbi.api.key</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>
    <menuitem
        id="biocell_conector_powerbi_key_menu"
        name="PowerBI Tokens API"
        action="biocell_conector_powerbi_key_action"
        groups="biocell_conector_powerbi.powerbi_edit_api,biocell_conector_powerbi.powerbi_read_api"
        parent="sale.menu_sale_report"
        sequence="20"/>
</odoo>
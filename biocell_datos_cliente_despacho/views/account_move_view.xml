<odoo>
	<record id="view_stock_picking_form_rca" model="ir.ui.view">
		<field name="name">view.stock.picking.form.rca</field>
		<field name="model">stock.picking</field>
		<field name="inherit_id" ref="stock.view_picking_form" />
		<field name="arch" type="xml">
			<xpath expr="//notebook//page[@name='note']" position="after">
				<page string="Información Clínica" name="info_cli">
					<group>
						<group>
					
						<field name="name_patient"/>
						<field name="payment_term_id"/>
						<field name="patient_vat"/>
						<field name="clinic_history"/>
						<field name="medic_center" />
						<field name="name_doctor" />
						</group>
						<group>
						<field name="sugery_date" />
						<field name="sugery_order" />
						<field name="procedure_clinic" />
						<field name="instrumentalist" />
						</group>
						<group>
						<field name="request_date" />
						<field name="schedulling_request_date" />
						<field name="user_id_sale" />
						<field name="categoria_rel" />
						</group>
						<group>
						<field name="cod_cirugia" />
						<field name="nro_gaveta" />
						</group>
					</group>
				</page>
				
			</xpath>
			
		</field>
	</record>

</odoo>
<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_picking_form_inherit_import_lotes_xlsx" model="ir.ui.view">
        <field name="name">stock.picking.import.lotes.xlsx</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='move_line_ids_without_package']" position="before">
                <group string="Importar Lotes xlsx"
                      attrs="{'invisible': ['|', ('state','not in',('done','cancel')), ('picking_type_code','!=','internal')]}">
                    <group>
                        <field name="remove_rest_xlsx" invisible="1"/>
                        <button class="oe_highlight" name="get_read_lotes_xlsx" type="object" string="Importar Lineas"/>
                    </group>
                    <group>
                        <field name="lotes_file_xlsx"/>
                    </group>
                </group>
            </xpath>

            <xpath expr="//field[@name='move_ids_without_package']" position="before">
                <group string="Importar Lotes xlsx"
                       attrs="{'invisible': ['|', ('state', '!=', 'draft'), ('picking_type_code','!=','internal')]}">
                    <group>
                        <button class="oe_highlight" name="get_read_lotes_xlsx" type="object" string="Importar Lineas"/>
                    </group>
                    <group>
                        <field name="lotes_file_xlsx"/>
                    </group>
                </group>
            </xpath>

            <xpath expr="//field[@name='note']" position="after">
                <group attrs="{'invisible': [('picking_type_code', '!=', 'internal')]}">
                    <group>
                        <field name="errores_txt_xlsx" readonly="1"/>
                    </group>
                </group>
            </xpath>

        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_biocell_generador_periodos_form" model="ir.ui.view">
        <field name="name">biocell_generador_periodos.form</field>
        <field name="model">period.generator</field>
        <field name="arch" type="xml">
            <form>
                <p>Este asistente le ayudará a generar Periodos para el año fiscal seleccionado</p>
                <group>
                    <group>
                        <field name="fiscal_year_id" required="1"/>
                    </group>
                </group>
                <footer>
                    <button name="generate_periods" string="Generar" type="object" class="oe_highlight"/>
                    <button special="cancel" string="Cancel" class="oe_link"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_biocell_generador_periodoss" model="ir.actions.act_window">
        <field name="name">Generar Periodos</field>
        <field name="res_model">period.generator</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_biocell_generador_periodos"
              parent="biocell_contabilidad_utilidad_062.menu_other_configurations"
              action="action_biocell_generador_periodoss"
              groups="account.group_account_manager"
              sequence="2"/>
</odoo>

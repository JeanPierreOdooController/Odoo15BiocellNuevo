<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="view_sale_order_category_form" model="ir.ui.view">
			<field name="name">view.sale.order.category.form</field>
			<field name="model">sale.order.category</field>
			<field name="arch" type="xml">
				<form string="type de Venta">
					<sheet>
						<group>
							<field name="name" required="1"/>
							<field name="description" required="1"/>
						</group>
					</sheet>
				</form>
			</field>
		</record>
		<record id="view_sale_order_category_tree" model="ir.ui.view">
			<field name="name">view.sale.order.category.tree</field>
			<field name="model">sale.order.category</field>
			<field name="arch" type="xml">
				<tree>
					<field name="name" required="1"/>
					<field name="description" required="1"/>
				</tree>
			</field>
		</record>
		<record id="view_sale_order_category" model="ir.actions.act_window">
			<field name="name">Categorias de ventas</field>
			<field name="res_model">sale.order.category</field>
			<field name="view_mode">tree,form</field>
			<field name="view_id" ref="view_sale_order_category_tree"/>
			<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
				Crea tu primera tabla de Categorias de ventas aquí
			</p>
			</field>
		</record>

		<menuitem 
			id="menu_sale_order_category" 
			name="Categorias de ventas" 
			sequence="2" 
			action="view_sale_order_category" 
			parent="sale.menu_sales_config"
            groups="sale_management.group_sale_order_template"
			/>

	</data>	
</odoo>
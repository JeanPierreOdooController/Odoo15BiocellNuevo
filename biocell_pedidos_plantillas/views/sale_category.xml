<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="view_sale_category_form" model="ir.ui.view">
			<field name="name">view.sale.category.form</field>
			<field name="model">sale.category</field>
			<field name="arch" type="xml">
				<form string="type de Venta">
					<sheet>
						<group>
							<field name="name" />
							<field name="description" />
						</group>
					</sheet>
				</form>
			</field>
		</record>
		<record id="view_sale_category_tree" model="ir.ui.view">
			<field name="name">view.sale.category.tree</field>
			<field name="model">sale.category</field>
			<field name="arch" type="xml">
				<tree>
					<field name="name" />
					<field name="description" />
				</tree>
			</field>
		</record>
		<record id="view_sale_category" model="ir.actions.act_window">
			<field name="name">Tipo de Categorias de ventas</field>
			<field name="res_model">sale.category</field>
			<field name="view_mode">tree,form</field>
			<field name="view_id" ref="view_sale_category_tree"/>
			<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">
				Crea tu primera tabla de Tipo de Categorias de ventas aquí
			</p>
			</field>
		</record>

		<menuitem 
			id="menu_sale_category" 
			name="Tipo de Categorias de ventas" 
			sequence="2" 
			action="view_sale_category" 
			parent="sale.menu_sales_config"
            groups="sale_management.group_sale_order_template"
			/>
	</data>	
</odoo>

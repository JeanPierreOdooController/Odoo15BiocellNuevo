<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_template_add" model="ir.ui.view">
            <field name="name">sale.order.template.add</field>
            <field name="model">sale.order.template</field>
            <field name="inherit_id" ref="sale_management.sale_order_template_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='company_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='company_id']" position="after">
                    <field name="sale_type_category_id"/>
                </xpath>
                <xpath expr="//label[@for='number_of_days']" position="before">
                    <field name="sale_type"/>
                    <field name="sale_type_id"/>
                </xpath>
            </field>
    </record>
</odoo>

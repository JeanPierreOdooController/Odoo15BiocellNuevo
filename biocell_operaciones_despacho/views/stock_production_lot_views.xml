<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_stock_production_lot_form_inherit_block_transfers" model="ir.ui.view">
        <field name="name">stock.production.lot.form.block.transfers</field>
        <field name="model">stock.production.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="block_transfers" groups="biocell_operaciones_despacho.block_products_and_lots"/>
            </xpath>
        </field>
    </record>
</odoo>

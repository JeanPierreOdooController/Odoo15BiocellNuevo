<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="view_product_template_form_inherit_block_transfers" model="ir.ui.view">
        <field name="name">product.template.form.block.transfers</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="block_transfers" groups="biocell_operaciones_despacho.block_products_and_lots"/>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_stock_quant_package_list_tree" model="ir.ui.view">
            <field name="name">stock.quant.package.list.tree</field>
            <field name="model">stock.quant.package.list</field>
            <field name="arch" type="xml">
                <tree string="Package Lista">
                        <field name="name" />
                        <field name="items_ids" />
                 </tree>
             </field>
        </record>


        <record id="view_stock_quant_package_list_form" model="ir.ui.view">
            <field name="name">stock.quant.package.list.form</field>
            <field name="model">stock.quant.package.list</field>
            <field name="arch" type="xml">
                <form string="Package Lista" version="7.0">
                    <group>
                        <field name="name" required="1"/>
                    </group>
                     <notebook>
                            <page string="Items">
                                <field name='items_ids'>
                                    <tree editable="bottom">
                                        <field name="product_id" required="1" />
                                        <field name="cantidad" required="1" />
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                 </form>
             </field>
        </record>

        <record id="action_stock_quant_package_list" model="ir.actions.act_window">
            <field name="name">Package Lista</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">stock.quant.package.list</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem name="Package Lista" id="menu_package_lista"
                 parent="stock.menu_stock_inventory_control" action="action_stock_quant_package_list"
                 sequence="103" />


        <record id="view_quant_package_form" model="ir.ui.view">
            <field name="name">stock.quant.package.form</field>
            <field name="model">stock.quant.package</field>
            <field name="inherit_id" ref="stock.view_quant_package_form"/>
            <field name="arch" type="xml">

               <field name="location_id" position="after">
                    <field name="template_package_list_id" required="1"/>
                    <field name="status_manual" required="1"/>
                    <field name="status_validate" readonly="1"/>
               </field>
            </field>
        </record>












        <record id="view_stock_package_reposition_tree" model="ir.ui.view">
            <field name="name">stock.package.reposition.tree</field>
            <field name="model">stock.package.reposition</field>
            <field name="arch" type="xml">
                <tree string="Reposición Paquetes">
                        <field name="package_id" />
                        <field name="details" />
                        <field name="picking_ids" />
                 </tree>
             </field>
        </record>


        <record id="view_stock_package_reposition_form" model="ir.ui.view">
            <field name="name">stock.package.reposition.form</field>
            <field name="model">stock.package.reposition</field>
            <field name="arch" type="xml">
                <form string="Reposición Paquetes" version="7.0">        
                    <header>
                        <button name="completar" class="oe_highlight" string="Revisar Paquete" type="object" states="draft"/>
                        <button name="validar" class="oe_highlight" string="Procesar" type="object" states="search"/>
                        <button name="volverborrador" class="oe_highlight" string="Volver a Borrador" type="object" states="search"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <group>
                        <field name="package_id" required="1" attrs="{'readonly':[('state','!=','draft')]}"/>
                    </group>
                     <notebook>
                            <page string="Detalle">
                                <field name='details'>
                                    <tree create="0" delete="0">
                                        <field name="product_id" readonly="1" />
                                        <field name="cantidad" readonly="1" />
                                        <field name="cantidad_x_procesar" readonly="1" />
                                        <field name="lotes" required="1" />
                                    </tree>
                                    <form>
                                        <group>
                                            <field name="product_id" readonly="1"/>
                                            <field name="cantidad" readonly="1"/>
                                            <field name="cantidad_x_procesar" readonly="1"/>
                                        </group>
                                        <notebook>
                                            <page string="Lotes/Series">
                                                <field name="lotes">
                                                    <tree editable="bottom">
                                                        <field name="product_id" readonly="1"/>
                                                        <field name="stock_lot_id" required="1" domain="[('location_id.usage','=','internal'),('product_id','=',product_id)]"/>
                                                        <field name="cantidad" required="1"/>
                                                    </tree>
                                                </field>
                                            </page>
                                        </notebook>
                                    </form>
                                </field>
                            </page>
                            <page string="Albaranes">
                                <field name="picking_ids" readonly="1"/>
                            </page>
                        </notebook>
                 </form>
             </field>
        </record>

        <record id="action_reposition_package" model="ir.actions.act_window">
            <field name="name">Reposición Paquetes</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">stock.package.reposition</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem name="Reposición Paquetes" id="menu_reposition_package"
                 parent="stock.menu_stock_inventory_control" action="action_reposition_package"
                 sequence="103" />


                 




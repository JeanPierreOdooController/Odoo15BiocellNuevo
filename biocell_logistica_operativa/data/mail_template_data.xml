<?xml version="1.0" ?>
<odoo>

    <!-- Mail template are declared in a NOUPDATE block
         so users can freely customize/delete them -->
    <data noupdate="1">
        <!--Email template -->
        <record id="email_template_edi_despatch" model="mail.template">
            <field name="name">Despatch: Send by email</field>
            <field name="model_id" ref="biocell_logistica_operativa.model_logistic_despatch"/>
            <field name="email_from">{{(object.despatch_user_id.email_formatted or user.email_formatted)}}</field>
            <field name="partner_to">{{object.partner_id.id}}</field>
            <field name="subject">{{object.company_id.name}} Despatch (Ref {{object.name or 'n/a'}})</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Dear
        <t t-if="object.partner_id.parent_id">:
            <t t-out="object.partner_id.name"/> (<t t-out="object.partner_id.parent_id.name"/>),
        </t>
        <t t-else="">:
            <t t-out="object.partner_id.name"/>,
        </t>
        <br /><br />
        Here is your
        <t t-if="object.name">:
            despatch <strong><t t-out="object.name"/></strong>
        </t>
        <t t-else="">:
            despatch
        </t>
        <t t-if="object.despatch_origin">:
            (with reference: <t t-out="object.despatch_origin"/>)
        </t>
        from <t t-out="object.company_id.name"/>.
        <br /><br />
        Do not hesitate to contact us if you have any questions.
    </p>
</div>
            </field>
            <field name="report_template" ref="logistic_despatchs"/>
            <field name="report_name">Despatch_{{(object.name or '').replace('/','_')}}{{object.state == 'draft' and '_draft' or ''}}</field>
            <field name="lang">{{object.partner_id.lang}}</field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
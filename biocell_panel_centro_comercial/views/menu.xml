<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="account_analytic_journal_view_tree" model="ir.ui.view">
        <field name="name">account.analytic.journal.view.tree</field>
        <field name="model">account.analytic.journal</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="codigo" />
                <field name="almacen_predeterminado" />
            </tree>
        </field>
    </record>
    
    <record id="account_analytic_journal_view_form" model="ir.ui.view">
        <field name="name">account.analytic.journal.view.form</field>
        <field name="model">account.analytic.journal</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="almacen_predeterminado" />
                            <field name="tipo_operacion_cliente" />
                        </group>
                        <group>
                            <field name="codigo" />
                            <field name="tipo_operacion_venta" />
                        </group>
                    </group>
                    <group name="accounting" string="Contabilidad">
                        <group>
                            <field 
                                name="serie_invoice" 
                                options="{'no_create': True, 'no_create_edit':True}" 
                                domain="[('type_document_id.code','=','01')]"
                            />
                            <field 
                                name="serie_sale_slip" 
                                options="{'no_create': True, 'no_create_edit':True}" 
                                domain="[('type_document_id.code','=','03')]"
                            />
                        </group>
                        <group>
                            <field 
                                name="serie_credit_note" 
                                widget="many2many_tags"
                                options="{'no_create': True, 'no_create_edit':True}" 
                                domain="[('type_document_id.code','=','07')]"
                            />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="account_analytic_journal_action" model="ir.actions.act_window">
        <field name="name">Centros</field>
        <field name="res_model">account.analytic.journal</field>
        <field name="view_mode">tree,form</field>
    </record>
    
    <menuitem
        id="account_analytic_journal_menu"
        name="Centro"
        action="account_analytic_journal_action"
        parent="sale.menu_sale_config"
        sequence="1"/>
</odoo>
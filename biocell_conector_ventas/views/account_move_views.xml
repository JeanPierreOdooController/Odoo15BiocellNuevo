<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Heredar la vista de formulario de account.move para agregar el campo Nro de Cotización -->
        <record id="account_move_form_nro_cotizacion" model="ir.ui.view">
            <field name="name">account.move.form.nro.cotizacion</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <!-- Agregar el campo Nro de Cotización después del campo partner_bank_id -->
                <xpath expr="(//field[@name='partner_bank_id'])[2]" position="after">
                    <field name="nro_cotizacion" attrs="{'invisible': [('move_type', 'not in', ['out_invoice', 'out_refund'])]}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_order_form_segmento_trauma_articulacion" model="ir.ui.view">
            <field name="name">sale.order.form.segmento.trauma.articulacion</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='procedure_clinic']" position="after">
                    <field name="articulacion_trauma_md"
                           attrs="{'invisible': [('segmento', 'not in', ('trauma', 'md_trauma'))]}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

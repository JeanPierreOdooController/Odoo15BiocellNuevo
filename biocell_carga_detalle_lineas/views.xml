<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_picking_form" model="ir.ui.view">
           <field name="name">stock.picking</field>
           <field name="model">stock.picking</field>
           <field name="inherit_id" ref="stock.view_picking_form"/>
           <field name="arch" type="xml">
               <xpath expr="//header" position="inside">
                    <button class="oe_highlight" name="importar_move_lines" type="object" string="Importar Lineas" attrs="{'invisible': [('state', 'not in',('assigned','confirmed'))]}"/>
               </xpath>
            </field>
    </record>

    <record id="importador_moves_lines_wizard" model="ir.ui.view">
        <field name="name">importador.moves.lines.wizard</field>
        <field name="model">importador.moves.lines</field>
        <field name="arch" type="xml">
            <form string="Importar Movimientos Almacen">
                <group>
                    <field name="import_product_type" widget="radio" />
                    <field name="warning" string=" " attrs="{'invisible':[('warning','=',False)]}" style="color:red ! important;"/>
                </group>
                <group>
                    <field name="company_id" readonly="1"/>
                    <field name="stock_picking_id" invisible="1" required="1"/>
                    <field name="mensaje_formato" readonly="1"/>
                </group>
                <group>
                    <field name="file" filename="name"/>
                    <field name="name" invisible="1"/>
                </group>
                <footer>
                    <button class="fa fa-upload btn-primary"  name="get_read_lotes" string="Importar" type="object"/>
                    o
                    <button string="Cancelar" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
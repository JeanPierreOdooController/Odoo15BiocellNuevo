<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="stock_picking_view_tree_add_factura_guia" model="ir.ui.view">
        <field name="name">stock.picking.view.tree.add.factura.guia</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="despatch_id" string="Nro de guía" optional="show" />
                <field name="invoice_id" string="Nro de factura" optional="show" />
            </xpath>
        </field>
    </record>
</odoo>
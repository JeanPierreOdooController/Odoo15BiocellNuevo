<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="consumption_sheet_report_view_tree" model="ir.ui.view">
        <field name="name">consumption.sheet.report.view.tree</field>
        <field name="model">consumption.sheet.report</field>
        <field name="arch" type="xml">
            <tree create="0" edit="0" delete="0">
                <field name="sale_order_id" /> 
                <field name="patient_name" /> 
                <field name="medical_center_id" /> 
                <field name="surgeon_id" /> 
                <field name="state" /> 
                <field name="product_code" /> 
                <field name="product_description" /> 
                <field name="surgery_date" /> 
                <field name="product_qty_consumed" /> 
                <field name="product_unit_price" /> 
                <field name="product_total_price" /> 
                <field name="subtotal" /> 
                <field name="tax_amount" /> 
                <field name="total_amount" /> 
                <field name="total_consumed_amount" /> 
            </tree>
        </field>
    </record>

    <record id="consumption_sheet_report_action_server" model="ir.actions.server">
        <field name="name">Hoja de Consumo</field>
        <field name="model_id" ref="model_consumption_sheet_report"/>
        <field name="binding_model_id" ref="model_consumption_sheet_report"/>
        <field name="state">code</field>
        <field name="code">action=model.get_report()</field>
    </record>

    <record id="consumption_sheet_report_view_search" model="ir.ui.view">
        <field name="name">consumption.sheet.report.view.search</field>
        <field name="model">consumption.sheet.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="sale_order_id" /> 
                <field name="patient_name" /> 
                <field name="medical_center_id" /> 
                <field name="surgeon_id" />
                <field name="product_code" /> 
            </search>
        </field>
    </record>

    <menuitem
        id="consumption_sheet_report_menu"
        name="Hoja de Consumo"
        action="consumption_sheet_report_action_server"
        parent="sale.menu_sale_report"
        sequence="10"/>

</odoo>

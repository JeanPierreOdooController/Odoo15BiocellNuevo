<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="action_sale_order_template_form_inherit" model="ir.ui.view">
			<field name="name">sale.order.template.form.inherit</field>
			<field name="model">sale.order</field>
			<field name="inherit_id" ref="sale_management.sale_order_form_quote"/>
			<field name="arch" type="xml">
				<xpath expr="//field[@name='sale_order_template_id']" position="after">
					<field name="plantilla_presupuesto_id"/>
				</xpath>
				<xpath expr="//field[@name='sale_order_template_id']" position="attributes">
					<attribute name="invisible">1</attribute>
				</xpath>
			</field>
		</record>
		<record id="action_sale_order_payment_form_inherit" model="ir.ui.view">
			<field name="name">sale.order.payment.form.inherit</field>
			<field name="model">sale.order</field>
			<field name="inherit_id" ref="sale.view_order_form"/>
			<field name="arch" type="xml">
				<xpath expr="//field[@name='payment_term_id']" position="after">
					<field name="plantilla_kardex_id"/>
				</xpath>
			</field>
		</record>
	</data>
</odoo>

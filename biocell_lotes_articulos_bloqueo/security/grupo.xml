<odoo>
    <record id="batch_editing_group_it" model="res.groups">
        <field name="name">Permitir edicción de lotes/series</field>
    </record>
    <record id="stock_production_lot_readonly_group" model="ir.ui.view">
        <field name="name">stock.production.lot.readonly.group</field>
        <field name="model">stock.production.lot</field>
        <field name="inherit_id" ref="product_expiry.view_move_form_expiry"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="can_edit_field" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="attrs">{'readonly': [('can_edit_field','=',False)]}</attribute>
            </xpath>   
            <xpath expr="//field[@name='product_id']" position="attributes">
                <attribute name="attrs">{'readonly': [('can_edit_field','=',False)]}</attribute>
            </xpath>   
            <xpath expr="//field[@name='ref']" position="attributes">
                <attribute name="attrs">{'readonly': [('can_edit_field','=',False)]}</attribute>
            </xpath>   
            <xpath expr="//field[@name='product_qty']" position="attributes">
                <attribute name="attrs">{'readonly': [('can_edit_field','=',False)]}</attribute>
            </xpath>   
            <xpath expr="//field[@name='company_id']" position="attributes">
                <attribute name="attrs">{'readonly': [('can_edit_field','=',False)]}</attribute>
            </xpath>   
            <xpath expr="//field[@name='expiration_date']" position="attributes">
                <attribute name="attrs">{'readonly': [('can_edit_field','=',False)]}</attribute>
            </xpath>   
            <xpath expr="//field[@name='note']" position="attributes">
                <attribute name="attrs">{'readonly': [('can_edit_field','=',False)]}</attribute>
            </xpath>   
        </field>
    </record>
</odoo>
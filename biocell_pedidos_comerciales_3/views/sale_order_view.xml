<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_order_form_agendar_button_ortobiologico" model="ir.ui.view">
            <field name="name">sale.order.form.agendar.button.ortobiologico</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='procedure_clinic']" position="after">
                    <field name="articulacion_medicina_deportiva" attrs="{'invisible': [('segmento', '!=', 'ortobiologico')]}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

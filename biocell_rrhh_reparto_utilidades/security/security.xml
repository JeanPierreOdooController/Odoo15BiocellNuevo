<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="group_biocell_rrhh_reparto_utilidades_root" model="res.groups">
			<field name="name">Utilidades</field>
			<field name="category_id" ref="base.module_category_human_resources_payroll"/>
			<field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
		</record>
		<record id="biocell_rrhh_reparto_utilidades_comp_rule" model="ir.rule">
			<field name="name">Utilidades multi-company</field>
			<field name="model_id" ref="model_biocell_rrhh_reparto_utilidades"/>
			<field name="global" eval="True"/>
			<field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
		</record>
	</data>
</odoo>
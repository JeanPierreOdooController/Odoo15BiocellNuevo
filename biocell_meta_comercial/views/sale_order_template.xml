                        </page>
				</xpath>
			</field>
		</record>



		<record id="action_sale_order_info_clinica_form_inherit" model="ir.ui.view">
			<field name="name">sale.order.info.clinicaform.inherit</field>
			<field name="model">sale.order</field>
			<field name="inherit_id" ref="sale_management.sale_order_form_quote"/>
			<field name="arch" type="xml">
				<xpath expr="//page" position="after">
					<page string="Información Clínica" name="clinic_information">
						<group>
							<group name="patient_info">
								<field name="name_patient"/>
								<field name="patient_vat"/>
								<field name="clinic_history"/>
								<field name="medic_center" domain="[('parent_id','=',partner_id) , ('type','=','medical_center')]"/>
								<field name="name_doctor" domain="[('is_medic','=',True)]"/>
							</group>
							<group name="date_info">
								<field name="sugery_date"/>
								<field name="sugery_order"/>
								<field name="procedure_clinic" invisible="1"/>
								<field name="procedure_clinic_id"/>
								<field name="instrumentalist" domain="[('is_instrumentalist','=',True)]"/>
							</group>
						</group>
						<group>
							<group name="aditional" string="ADICIONAL">
								<field name="request_date"/>
								<field name="schedulling_request_date"/>
							</group>
							<group>
								
							</group>
						</group>
					</page>
				</xpath>
			</field>
		</record>
		<record id="action_sale_order_newfield_form_inherit" model="ir.ui.view">
			<field name="name">sale.order.newfield.inherit</field>
			<field name="model">sale.order</field>
			<field name="inherit_id" ref="sale.view_order_form"/>
			<field name="arch" type="xml">
				<xpath expr="//field[@name='partner_id']" position="before">
					
					<field name="shop_id"/>
								
				</xpath>
				<xpath expr="//group[@name='order_details']//field[@name='validity_date']" position="replace">
					<field name="validity_term" />
					<field name="validity_date" string="Validez"/>
				</xpath>

				<xpath expr="//group[@name='order_details']" position="inside">
					<field name="plantilla_kardex_id"  widget="many2many_tags"/>
					<field name="warehouse_id"/>
				</xpath>
				<field name="tax_totals_json" position="before">

										<button name="aplicar_descuento" type="object" string="Aplicar Descuento" attrs="{'invisible': [ ('state', 'in', ['sale', 'done','cancel'])]}" colspan="1"/>
										<field name="descuento_masivo" nolabel="1" attrs="{'readonly':[('state','=',('sale','done','cancel'))]}" colspan="1" />
				</field>

			</field>
		</record>

	</data>
</odoo>
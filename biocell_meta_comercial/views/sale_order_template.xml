										<field name="note_kardex" class="oe-bordered-editor" nolabel="1" placeholder="Términos y condiciones..."/>
									</group>
									<group class="oe_subtotal_footer oe_right" colspan="2" name="sale_total">
										<button name="aplicar_descuento" type="object" string="Aplicar Descuento" attrs="{'invisible': [ ('state', 'in', ['sale', 'done','cancel'])]}" colspan="1"/>

                            <field name="order_line_stock" context="{'biocell_parametro_venta_defecto':'stock'}" widget="section_and_note_one2many" mode="tree" attrs="{'readonly': [('state', 'in', ('done','cancel'))]}">
                                
                                <tree string="Línea de kardex" editable="bottom">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>

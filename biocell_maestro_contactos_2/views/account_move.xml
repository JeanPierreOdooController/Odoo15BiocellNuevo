<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_form_inherit_vendedor_it" model="ir.ui.view">
        <field name="name">account.move.form.inherit.vendedor.it</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other_info']//group//group[@name='sale_info_group']/field[@name='invoice_user_id']" position="after">
                <field name="seller_id" options="{'no_edit': True, 'no_create': True, 'no_delete':True}"/>
            </xpath>            
        </field>
    </record>
</odoo>

